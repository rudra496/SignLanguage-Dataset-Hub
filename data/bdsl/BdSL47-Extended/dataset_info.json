  "description": "Extended version of BdSL47 dataset with additional signers, improved image quality, and MediaPipe pose annotations. Contains RGB images of Bangla Sign Language alphabet and digits from multiple camera sources with diverse lighting conditions.",
  
  "base_dataset": {
    "name": "BdSL47",
    "citation": "Afzal, M. et al. (2022). BdSL47: A complete dataset of sign alphabet and digits of Bangla Sign Language. Data Dryad.",
    "doi": "10.5061/dryad.1vhhmgqwk"
  },
  
  "extensions": [
    "Additional 5 signers (original: 10, extended: 15)",
    "Higher resolution images (original: 400x400, extended: 640x480)",
    "MediaPipe hand pose annotations",
    "Augmented samples with rotation and lighting variations",
    "Background diversity (indoor, outdoor, cluttered)"
  ],
  
  "statistics": {
    "total_images": 70500,
    "signs": 47,
    "signers": 15,
    "images_per_sign_per_signer": 100,
    "image_formats": ["PNG", "JPG"],
    "resolution": "640x480 (primary), 400x400 (legacy)"
  },
  
  "signs": {
    "alphabet": {
      "count": 37,
      "range": "অ to ঁ (Bengali alphabet)",
      "samples_per_sign": 1500
    },
    "digits": {
      "count": 10,
      "range": "০ to ৯ (Bengali digits 0-9)",
      "samples_per_sign": 1500
    }
  },
  
  "annotations": {
    "hand_landmarks": {
      "format": "JSON",
      "model": "MediaPipe Hands",
      "landmarks_per_hand": 21,
      "coordinate_system": "normalized [0,1]"
    },
    "bounding_boxes": {
      "format": "YOLO",
      "classes": 47
    },
    "segmentation_masks": {
      "format": "PNG",
      "availability": "subset (10,000 images)"
    }
  },
  
  "splits": {
    "train": {
      "images": 56400,
      "signers": 12
    },
    "val": {
      "images": 7050,
      "signers": 1
    },
    "test": {
      "images": 7050,
      "signers": 2
    }
  },
  
  "collection_info": {
    "locations": ["Dhaka", "Sylhet", "Chittagong"],
    "period": "2024-01 to 2025-12",
    "cameras": ["Samsung Galaxy S21", "iPhone 13", "Logitech C920"],
    "lighting_conditions": ["indoor_artificial", "indoor_natural", "outdoor_daylight"],
    "backgrounds": ["plain_white", "plain_black", "cluttered_office", "outdoor"]
  },
  
  "file_structure": {
    "images/": "RGB images organized by sign_id/signer_id/",
    "annotations/": "JSON files with hand landmarks and bounding boxes",
    "masks/": "Binary segmentation masks (subset)",
    "splits/": "Train/val/test split files"
  },
  
  "download": {
