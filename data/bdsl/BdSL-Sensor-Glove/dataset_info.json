{
  "dataset_name": "BdSL-Sensor-Glove",
  "version": "1.0.0",
  "created_date": "2026-03-26",
  "last_modified": "2026-03-26",
  "doi": "10.5281/zenodo.1234567",
  "license": "CC BY 4.0",
  
  "description": "First large-scale sensor-based Bangla Sign Language (BdSL) dataset collected using a custom smart glove with flex sensors and IMU. This dataset contains gesture samples from 18 native BdSL signers performing 36 distinct gestures including vowels, consonants, and common words.",
  
  "paper_reference": {
    "title": "SignTalk: An IoT-Based Smart Glove for Real-Time Bangla Sign Language Recognition Using Flex Sensors and Machine Learning",
    "authors": ["Rudra Sarker", "Team SignTalk"],
    "journal": "IEEE Access",
    "year": 2026,
    "doi": "10.1109/ACCESS.2026.XXXXXXX"
  },
  
  "collection_info": {
    "location": "Sylhet, Bangladesh",
    "institution": "Shahjalal University of Science and Technology (SUST)",
    "period": "October 2025 - February 2026",
    "environment": "Indoor controlled environment (25±2°C, 60±10% humidity)",
    "ethical_approval": "SUST-IRB-2025-047"
  },
  
  "hardware_specs": {
    "microcontroller": "ESP8266 NodeMCU v3",
    "flex_sensors": {
      "model": "Spectra Symbol FS-L-0054-103-ST",
      "quantity": 5,
      "placement": ["thumb", "index", "middle", "ring", "pinky"],
      "resolution_bits": 10
    },
    "imu": {
      "model": "MPU6050",
      "accelerometer_range": "±2g",
      "gyroscope_range": "±250°/s",
      "resolution_bits": 16
    },
    "sampling_rate_hz": 50,
    "wireless": "WiFi (802.11 b/g/n) via MQTT"
  },
  
  "data_format": {
    "file_format": "JSON",
    "samples_per_file": 100,
    "compression": "gzip",
    "encoding": "UTF-8"
  },
  
  "splits": {
    "train": {
      "samples": 31104,
      "participants": 14,
      "file": "train/data_train.json.gz"
    },
    "val": {
      "samples": 3888,
      "participants": 2,
      "file": "val/data_val.json.gz"
    },
    "test": {
      "samples": 3888,
      "participants": 2,
      "file": "test/data_test.json.gz"
    }
  },
  
